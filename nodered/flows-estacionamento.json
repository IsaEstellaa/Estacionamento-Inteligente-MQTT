    {
        "id": "f8d6e99e88e0ac1f",
        "type": "function",
        "z": "09c2c15ffa1b32b4",
        "name": "function 2",
        "func": "const sectors = [\"A\", \"B\", \"C\"];\n\nconst sector =\n    sectors[Math.floor(Math.random() * sectors.length)];\n\nconst spotNumber =\n    String(Math.floor(Math.random() * 30) + 1).padStart(2, \"0\");\n\nconst spotId = `${sector}-${spotNumber}`;\n\nconst baseTopic =\n    `campus/parking/sectors/${sector}/spots/${spotId}/events`;\n\nconst now = Date.now();\n\n// 🔥 apenas 2 estados (sem loop)\nconst events = [\n    { state: \"OCCUPIED\", delay: 0 },\n    { state: \"FREE\", delay: 1500 }\n];\n\nevents.forEach((e, i) => {\n\n    setTimeout(() => {\n\n        node.send({\n            topic: baseTopic,\n            payload: JSON.stringify({\n                eventId: now + \"-\" + i,\n                ts: new Date().toISOString(),\n                sectorId: sector,\n                spotId,\n                state: e.state,\n                source: \"simple-toggle\"\n            })\n        });\n\n    }, e.delay);\n\n});\n\nreturn null;",
