    {
        "id": "1cdb1bd8a0ddeb14",
        "type": "function",
        "z": "09c2c15ffa1b32b4",
        "name": "Ocupar A",
        "func": "const messages = [];\n\nfor (let i = 1; i <= 30; i++) {\n\n    const spotId =\n        `A-${String(i).padStart(2, '0')}`;\n\n    messages.push({\n        topic:\n            `campus/parking/sectors/A/spots/${spotId}/events`,\n\n        payload: JSON.stringify({\n            eventId: Date.now() + '-' + i,\n            ts: new Date().toISOString(),\n            sectorId: 'A',\n            spotId,\n            state: 'OCCUPIED',\n            source: 'dashboard'\n        })\n    });\n}\n\nreturn [messages];",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
