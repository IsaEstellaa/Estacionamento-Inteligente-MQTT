        "order": 0,
        "width": 0,
        "height": 0,
        "format": "<div style=\"display:flex\">\n  <div ng-repeat=\"sector in msg.payload.sectors\" style=\"margin-bottom:20px; flex:1; display:flex;flex-direction:column;align-items:center; gap:5px\">\n\n    <h2>Setor {{sector.sectorId}}</h2>\n\n    <div style=\"\n      display:grid;\n      grid-template-columns: repeat(6, 45px);\n      gap:5px;\n    \">\n\n      <div ng-repeat=\"spot in sector.spots\" style=\"\n          width:45px;\n          height:45px;\n          border-radius:5px;\n          background-color:\n            {{spot.state === 'FREE' ? '#0cbd0c' : '#d12121'}};\n          display:flex;\n          align-items:center;\n          justify-content:center;\n          color:white;\n          font-size:10px;\n          font-weight:bold;\n        \">\n\n        {{spot.spotId}}\n\n      </div>\n\n    </div>\n\n  </div>\n</div>",
